{
  "family": "burntz-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::209479269102:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "burntz",
      "image": "209479269102.dkr.ecr.ap-northeast-2.amazonaws.com/burntz:latest",
      "portMappings": [
        { "containerPort": 8080, "protocol": "tcp" }
      ],
      "essential": true,
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "dev" },
        { "name": "DB_URL", "value": "jdbc:postgresql://burntz-db.cdgiwaocqbwu.ap-northeast-2.rds.amazonaws.com:5432/burntz?sslmode=require&stringtype=unspecified"},
        { "name": "DB_USERNAME", "value": "root"},
        { "name": "DB_PASSWORD", "value": "burntz1234" }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-create-group": "true",
          "awslogs-group": "/ecs/burntz-dev",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs",
          "mode": "non-blocking",
          "max-buffer-size": "25m"
        }
      },

      "healthCheck": {
        "retries": 3,
        "command": ["CMD-SHELL","curl -fsS http://localhost:8080/actuator/health || exit 1"],
        "timeout": 5,
        "interval": 30,
        "startPeriod": 60
      }
    }
  ]
}