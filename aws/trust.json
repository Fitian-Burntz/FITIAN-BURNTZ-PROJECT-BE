{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::209479269102:oidc-provider/token.actions.githubusercontent.com"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringLike": {
          "token.actions.githubusercontent.com:sub": [
            "repo:Fitian-Burntz/FITIAN-BURNTZ-PROJECT-BE:ref:refs/heads/develop",
            "repo:Fitian-Burntz/FITIAN-BURNTZ-PROJECT-BE:ref:refs/heads/main",
            "repo:Fitian-Burntz/FITIAN-BURNTZ-PROJECT-BE:pull_request"
          ]
        },
        "StringEquals": {
          "token.actions.githubusercontent.com:aud": "sts.amazonaws.com"
        }
      }
    }
  ]
}
